<fieldset class="options">
	<legend>{{#if legend}}{{legend}}{{else}}[Velg noe under]{{/if}}</legend>
	{{#each options}}
	<div class="custom-checkbox{{#if horizontal}} horizontal{{/if}}">
		<input id="{{id}}" name="checkbox" type="checkbox"{{#if checked}} checked="checked"{{/if}}>
		<label for="{{id}}">{{label}}</label>
	</div>
	{{/each}}
</fieldset>